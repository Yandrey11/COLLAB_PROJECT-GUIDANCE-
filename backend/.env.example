# Copy to .env and fill in your values. Never commit .env.

# 🌐 Frontend
CLIENT_URL=http://localhost:5173
NODE_ENV=development
TRUST_PROXY=false

# Session cookie policy for OAuth/session middleware
# Allowed values: lax, strict, none
# Use `none` for cross-site frontend/backend deployments (requires HTTPS/secure cookie).
SESSION_COOKIE_SAMESITE=lax

# Security middleware toggle (set false for emergency rollback)
ENABLE_HELMET=true

# Request body caps (protect against oversized payload abuse)
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb

# Upload access mode:
# - public: legacy /uploads static files are public
# - hardened: disable public static serving; use authenticated /api/uploads/* access
UPLOADS_ACCESS_MODE=hardened

# Restrict admin account bootstrap
ALLOW_ADMIN_BOOTSTRAP=false
ADMIN_BOOTSTRAP_SECRET=

# Permission/security rollout toggles
# true = temporary compatibility mode for accounts missing permissions
ALLOW_LEGACY_PERMISSION_BYPASS=true
# true = require every authenticated request to have an active Session record
REQUIRE_ACTIVE_SESSION=false

# Temp cleanup scheduler for generated files in backend/temp
TEMP_CLEANUP_ENABLED=true
TEMP_FILE_TTL_HOURS=24

# 🧠 MongoDB
MONGO_URI=your_mongodb_connection_string
MONGO_URI_DIRECT=your_mongodb_direct_connection_string

# 🔐 Required secrets (must be set - never store in database)
JWT_SECRET=your_secure_jwt_secret_min_32_chars
SESSION_SECRET=your_secure_session_secret_min_32_chars

# Encrypt Google tokens in DB (32+ chars; falls back to JWT_SECRET if unset)
TOKEN_ENCRYPTION_KEY=optional_separate_encryption_key

# Encrypt PII fields at rest (AES-256-GCM). Set to a 64-char hex string
# (32 random bytes hex-encoded). If unset, derived from JWT_SECRET via scrypt.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=

# 🔒 reCAPTCHA
RECAPTCHA_SECRET_KEY=your_recaptcha_secret
RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# 📧 Email
EMAIL_USER=your_email
EMAIL_PASS=your_app_password

# 🔑 Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
GOOGLE_ADMIN_CALLBACK_URL=
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_CALENDAR_REDIRECT_URI=
GOOGLE_ANALYTICS_REDIRECT_URI=
GOOGLE_DRIVE_FOLDER_ID=
