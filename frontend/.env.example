VITE_API_URL=https://your-production-api.example.com
# Required in production builds. In development, the app can fallback to localhost.
# Copy to .env and fill in values (Vite only exposes vars prefixed with VITE_)

VITE_API_URL=http://localhost:5000

# Google reCAPTCHA v2 "I'm not a robot" site key (public). Must pair with RECAPTCHA_SECRET_KEY on the backend.
VITE_RECAPTCHA_SITE_KEY=
